<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:background="#FF121212"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:padding="24dp"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">

        <TextView
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="悬浮窗配置"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:textSize="16sp"
            android:textColor="#FFAAAAAA"
            android:id="@+id/tv_style_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="悬浮窗样式"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_style_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_style_label">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_normal"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checkable="true"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="#FF1E1E1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#FF444444"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:textSize="16sp"
                        android:textColor="#FFFFFFFF"
                        android:id="@+id/rb_normal"
                        android:clickable="false"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="常规"
                        android:buttonTint="#FF4FC3F7" />

                    <TextView
                        android:textSize="12sp"
                        android:textColor="#FF888888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="完整导航信息" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_minimal"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checkable="true"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="#FF1E1E1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#FF444444"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:textSize="16sp"
                        android:textColor="#FFFFFFFF"
                        android:id="@+id/rb_minimal"
                        android:clickable="false"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="灵动岛"
                        android:buttonTint="#FF4FC3F7" />

                    <TextView
                        android:textSize="12sp"
                        android:textColor="#FF888888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="精简灵动岛风格" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <TextView
            android:textSize="16sp"
            android:textColor="#FFAAAAAA"
            android:id="@+id/tv_scale_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="悬浮窗缩放"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_style_container" />

        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FF4FC3F7"
            android:id="@+id/tv_scale_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.0x"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_scale_label" />

        <SeekBar
            android:id="@+id/sb_scale"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:max="15"
            android:progress="5"
            android:progressTint="#FF4FC3F7"
            android:thumbTint="#FF4FC3F7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_scale_label" />

        <LinearLayout
            android:id="@+id/layout_scale_range"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sb_scale">

            <TextView
                android:textSize="12sp"
                android:textColor="#FF666666"
                android:gravity="start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="0.5x"
                android:layout_weight="1" />

            <TextView
                android:textSize="12sp"
                android:textColor="#FF666666"
                android:gravity="end"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="2.0x"
                android:layout_weight="1" />
        </LinearLayout>

        <TextView
            android:textSize="16sp"
            android:textColor="#FFAAAAAA"
            android:id="@+id/tv_theme_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="主色调"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_scale_range" />

        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/ll_theme_colors"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_theme_label" />

        <TextView
            android:textSize="14sp"
            android:textColor="#FF888888"
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_theme_colors" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
