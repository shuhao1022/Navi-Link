<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_dashboard"
    android:background="#FF1A1A2E"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="70dp">

    <!-- 顶部: 时间 -->
    <TextView
        android:layout_centerInParent="true"
        android:id="@+id/tv_time"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="#FFFFFFFF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="--:--" />

<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="match_parent">
    <ImageView
        android:layout_gravity="center_vertical"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/iv_time"/>
    <TextView
        android:layout_marginStart="10dp"
        android:id="@+id/tv_eta"
        android:textSize="20sp"
        android:textColor="#AAFFFFFF"
        android:gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:text="--:-- 到" />

    <ImageView
        android:layout_marginStart="30dp"
        android:layout_gravity="center_vertical"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/iv_trip"/>
    <TextView
        android:layout_marginStart="10dp"
        android:id="@+id/tv_distance"
        android:textSize="20sp"
        android:textColor="#AAFFFFFF"
        android:gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:text="-km" />
</LinearLayout>
</RelativeLayout>
    <LinearLayout
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_marginTop="70dp"
        android:layout_height="match_parent">

       <FrameLayout
           android:layout_width="0dp"
           android:layout_height="match_parent"
           android:layout_weight="1">
           <RelativeLayout
               android:layout_marginTop="20dp"
               android:layout_gravity="center_horizontal"
               android:paddingStart="20dp"
               android:paddingEnd="20dp"
               android:layout_width="300dp"
               android:layout_height="80dp">

               <ImageView
                   android:layout_marginEnd="20dp"
                   android:id="@+id/iv_turn_icon"
                   android:layout_width="56dp"
                   android:layout_height="56dp"
                   android:layout_centerVertical="true"
                   android:scaleType="centerInside"
                   android:src="@mipmap/ic_navi_u_turn"
                   app:tint="#FFFFFF"/>
               <LinearLayout
                   android:layout_toRightOf="@id/iv_turn_icon"
                   android:id="@+id/ll_distance_container"
                   android:layout_width="wrap_content"
                   android:layout_height="40dp"
                   android:gravity="bottom"
                   android:orientation="horizontal">

                   <TextView
                       android:id="@+id/tv_distance_num"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:includeFontPadding="false"
                       android:text="100"
                       android:textColor="#FFFFFF"
                       android:textSize="36sp"
                       android:textStyle="bold" />

                   <TextView
                       android:id="@+id/tv_distance_unit"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:layout_marginStart="4dp"
                       android:text="米"
                       android:textColor="#FFFFFF"
                       android:textSize="20sp"
                       android:textStyle="bold" />

                   <TextView
                       android:id="@+id/tv_action"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:layout_marginStart="8dp"
                       android:text="进入"
                       android:textColor="#888888"
                       android:textSize="20sp"
                       android:textStyle="bold" />
               </LinearLayout>

               <TextView
                   android:gravity="center_vertical"
                   android:layout_alignParentBottom="true"
                   android:layout_toRightOf="@id/iv_turn_icon"
                   android:id="@+id/tv_road_name"
                   android:layout_width="match_parent"
                   android:layout_height="40dp"
                   android:ellipsize="end"
                   android:maxLines="1"
                   android:text="坂雪岗大道"
                   android:textColor="#FFFFFF"
                   android:textSize="24sp"
                   android:textStyle="bold"/>
           </RelativeLayout>
           <include
               android:layout_gravity="center_horizontal"
               layout="@layout/layout_floating_traffic_light_group"
               android:layout_width="wrap_content"
               android:layout_height="50dp"
               android:layout_marginTop="120dp"/>
           <ImageView
               android:layout_marginBottom="10dp"
               android:layout_gravity="center_horizontal|bottom"
               android:id="@+id/iv_car"
               android:src="@drawable/iv_car"
               android:scaleType="fitCenter"
               android:layout_width="200dp"
               android:layout_height="120dp"
               android:layout_marginTop="16dp" />
           <ImageView
               android:layout_marginBottom="-150dp"
               android:layout_width="match_parent"
               android:layout_height="match_parent"
               android:scaleType="centerInside"
               android:src="@drawable/a_41"/>
       </FrameLayout>
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/iv_bg"
                android:src="@drawable/iv_rev_bg_drak"
                android:scaleType="fitXY"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />
            <ImageView
                android:id="@+id/iv_speedometer"
                android:src="@drawable/sd_1"
                android:scaleType="fitXY"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true" />

            <!-- 速度数字 -->
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tv_speed"
                    android:textSize="100sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFFFF"

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0" />
                <TextView
                    android:id="@+id/tv_speed_unit"
                    android:textSize="20sp"
                    android:layout_marginTop="-20dp"
                    android:textColor="#AAFFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:text="km/h" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</FrameLayout>
