<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_interval_container"
    android:layout_width="wrap_content"
    android:layout_height="32dp"
    android:orientation="horizontal"
    android:background="@drawable/bg_interval_speed_capsule"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="8dp"
    android:visibility="gone">

    <!-- Prefix / Status text -->
    <TextView
        android:id="@+id/tv_interval_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="区间测速"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginEnd="8dp"
        android:includeFontPadding="false"/>

    <!-- Dynamic info (Speed / Distance) -->
    <TextView
        android:id="@+id/tv_interval_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="前方 100m"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginEnd="8dp"
        android:includeFontPadding="false"/>

    <!-- Speed Limit icon -->
    <FrameLayout
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:background="@drawable/bg_camera_speed_circle">
        <TextView
            android:id="@+id/tv_interval_limit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="80"
            android:textColor="#000000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:includeFontPadding="false"/>
    </FrameLayout>
</LinearLayout>
