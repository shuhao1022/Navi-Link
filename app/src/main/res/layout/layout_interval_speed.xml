<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_interval_container"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:background="@drawable/bg_interval_speed_capsule_blue"
    android:gravity="center_vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:visibility="gone">

    <!-- 1. 当前实时速度（左侧白圈） -->
    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_white">

            <TextView
                android:layout_gravity="center"
                android:id="@+id/tv_interval_cur_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FF0A60FE"
                android:textSize="20sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

    </FrameLayout>

    <!-- 2. 平均车速 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_interval_avg_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/tv_interval_avg_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="平均车速"
            android:textColor="#DCE8FF"
            android:textSize="10sp"
            android:includeFontPadding="false"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <!-- 3. 剩余里程 / 距离起点 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_interval_dist_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/tv_interval_dist_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="剩余里程"
            android:textColor="#DCE8FF"
            android:textSize="10sp"
            android:includeFontPadding="false"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <!-- 4. 区间限速值（右侧红圈白底限速牌） -->
    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_camera_speed_circle">

        <TextView
            android:id="@+id/tv_interval_limit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="100"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />
    </FrameLayout>

</LinearLayout>
