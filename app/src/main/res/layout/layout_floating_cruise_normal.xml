<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/window_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <FrameLayout
        android:id="@+id/root_layout"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        android:background="@drawable/bg_floating_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- 第一行：速度 + 路名 + 限速 -->
            <LinearLayout
                android:id="@+id/ll_cruise_normal_first_row"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_cn_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="6dp"

                    android:text="0"
                    android:textColor="#FF0099FF"
                    android:textSize="40sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_cn_road_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"

                    android:layout_marginEnd="6dp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="无名道路"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp" />

                <com.navi.link.view.CameraWarningView
                    android:visibility="visible"
                    android:id="@+id/ll_cn_camera_dist"
                    android:background="@drawable/bg_traffic_light_capsule"
                    android:paddingEnd="5dp"
                    android:paddingStart="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp" />

            </LinearLayout>

            <!-- 第二行：红绿灯组 -->
            <LinearLayout
                android:id="@+id/ll_cn_traffic_lights_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone" />

            <!-- 车道线组件 -->
            <com.navi.link.view.LaneLineView
                android:id="@+id/lane_line_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

        </LinearLayout>
    </FrameLayout>
</FrameLayout>
