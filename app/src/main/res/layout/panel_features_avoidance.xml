<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panel_features_avoidance"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none">

    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Card 3: 功能与避让 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_group_features"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/panelCardBgColor"
            app:cardCornerRadius="16dp"
            app:strokeColor="?attr/panelDividerColor"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_operation"
                    android:text="功能与避让"
                    android:textSize="14sp"
                    android:textColor="#FF4FC3F7"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- Option 8: Auto Start on Boot Switch Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_auto_start_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:text="开机自启"
                                android:textSize="15sp"
                                android:textColor="?attr/panelTextColorPrimary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:id="@+id/tv_auto_start_status"
                                android:text="通电或开机时自动启动悬浮窗服务"
                                android:textSize="12sp"
                                android:textColor="?attr/panelTextColorSecondary"
                                android:layout_marginTop="2dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/cb_auto_start_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="?attr/panelDividerColor" />

                <!-- Option 1: Cruise Switch Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_cruise_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:text="启用巡航窗口"
                                android:textSize="15sp"
                                android:textColor="?attr/panelTextColorPrimary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:id="@+id/tv_cruise_status"
                                android:text="巡航窗已启用"
                                android:textSize="12sp"
                                android:textColor="?attr/panelTextColorSecondary"
                                android:layout_marginTop="2dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/cb_cruise_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="?attr/panelDividerColor" />

                <!-- Option 3: Avoid Foreground Switch Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_avoid_foreground_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:text="高德前台避让"
                                android:textSize="15sp"
                                android:textColor="?attr/panelTextColorPrimary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:id="@+id/tv_avoid_foreground_status"
                                android:text="前台正常显示浮窗"
                                android:textSize="12sp"
                                android:textColor="?attr/panelTextColorSecondary"
                                android:layout_marginTop="2dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/cb_avoid_foreground_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="?attr/panelDividerColor" />

                <!-- 路口放大图自动隐藏 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_cross_map_hide_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:text="路口放大图自动隐藏"
                                android:textSize="15sp"
                                android:textColor="?attr/panelTextColorPrimary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:id="@+id/tv_cross_map_hide_status"
                                android:text="高德显示路口放大图时隐藏悬浮窗"
                                android:textSize="12sp"
                                android:textColor="?attr/panelTextColorSecondary"
                                android:layout_marginTop="2dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/cb_cross_map_hide_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="?attr/panelDividerColor" />

                <!-- Option 4: Overspeed Warning Switch Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_overspeed_warning_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="12dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1">

                                <TextView
                                    android:text="超速红色提醒"
                                    android:textSize="15sp"
                                    android:textColor="?attr/panelTextColorPrimary"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content" />

                                <TextView
                                    android:id="@+id/tv_overspeed_warning_status"
                                    android:text="超速时车速红色报警并闪烁"
                                    android:textSize="12sp"
                                    android:textColor="?attr/panelTextColorSecondary"
                                    android:layout_marginTop="2dp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content" />
                            </LinearLayout>

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/cb_overspeed_warning_enabled"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:clickable="false"
                                android:focusable="false" />
                        </LinearLayout>

                        <!-- 超速阈值选择行 -->
                        <LinearLayout
                            android:id="@+id/ll_overspeed_threshold_row"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="12dp"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:text="超速阈值"
                                android:textSize="13sp"
                                android:textColor="#FFAAAAAA"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="12dp" />

                            <LinearLayout
                                android:orientation="horizontal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:id="@+id/chip_overspeed_0"
                                    android:text="0%"
                                    android:textSize="13sp"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="4dp"
                                    android:layout_marginEnd="6dp"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:minWidth="40dp"
                                    android:foreground="?android:attr/selectableItemBackground"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />

                                <TextView
                                    android:id="@+id/chip_overspeed_10"
                                    android:text="10%"
                                    android:textSize="13sp"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="4dp"
                                    android:layout_marginEnd="6dp"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:minWidth="40dp"
                                    android:foreground="?android:attr/selectableItemBackground"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />

                                <TextView
                                    android:id="@+id/chip_overspeed_20"
                                    android:text="20%"
                                    android:textSize="13sp"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="4dp"
                                    android:layout_marginEnd="6dp"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:minWidth="40dp"
                                    android:foreground="?android:attr/selectableItemBackground"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />

                                <TextView
                                    android:id="@+id/chip_overspeed_30"
                                    android:text="30%"
                                    android:textSize="13sp"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="4dp"
                                    android:layout_marginEnd="6dp"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:minWidth="40dp"
                                    android:foreground="?android:attr/selectableItemBackground"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />

                                <TextView
                                    android:id="@+id/chip_overspeed_50"
                                    android:text="50%"
                                    android:textSize="13sp"
                                    android:gravity="center"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="4dp"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:minWidth="40dp"
                                    android:foreground="?android:attr/selectableItemBackground"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />

                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="?attr/panelDividerColor" />

                <!-- Option 4.5: Lane Line Background Hide Switch Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_hide_lane_line_bg_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:text="车道线背景隐藏"
                                android:textSize="15sp"
                                android:textColor="?attr/panelTextColorPrimary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:id="@+id/tv_hide_lane_line_bg_status"
                                android:text="背景默认显示"
                                android:textSize="12sp"
                                android:textColor="?attr/panelTextColorSecondary"
                                android:layout_marginTop="2dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/cb_hide_lane_line_bg_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 4: 仪表盘副屏设置 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_group_cluster"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/panelCardBgColor"
            app:cardCornerRadius="16dp"
            app:strokeColor="?attr/panelDividerColor"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_title_cluster_settings"
                    android:text="仪表盘副屏设置"
                    android:textSize="14sp"
                    android:textColor="#FF4FC3F7"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- Option 6: Secondary Screen Mirroring Switch Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_cluster_mirror_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:text="启用副屏投屏"
                                android:textSize="15sp"
                                android:textColor="?attr/panelTextColorPrimary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:id="@+id/tv_cluster_mirror_status"
                                android:text="副屏镜像显示悬浮窗信息"
                                android:textSize="12sp"
                                android:textColor="?attr/panelTextColorSecondary"
                                android:layout_marginTop="2dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/cb_cluster_mirror_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="?attr/panelDividerColor" />

                <!-- Option 7.5: Hide Main Screen on Cluster Active Switch Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_hide_main_when_cluster_active"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:text="副屏显示时隐藏主屏"
                                android:textSize="15sp"
                                android:textColor="?attr/panelTextColorPrimary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:id="@+id/tv_hide_main_when_cluster_active_status"
                                android:text="副屏成功显示后自动隐藏主屏悬浮窗"
                                android:textSize="12sp"
                                android:textColor="?attr/panelTextColorSecondary"
                                android:layout_marginTop="2dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/cb_hide_main_when_cluster_active"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="#1AFFFFFF" />

                <!-- Option 7: Display Selection Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_cluster_display_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:text="选择投屏屏幕"
                                android:textSize="15sp"
                                android:textColor="#FFFFFFFF"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:id="@+id/tv_cluster_display_select_status"
                                android:text="当前选择: 自动选择 (首个副屏幕)"
                                android:textSize="12sp"
                                android:textColor="#FF888888"
                                android:layout_marginTop="2dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btn_adjust_cluster_pos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="?android:attr/selectableItemBackground"
                            android:gravity="center"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:text="调位"
                            android:textColor="#FF4FC3F7"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="#1AFFFFFF" />

                <!-- Option 7.6: 副屏投屏缩放设置 -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:layout_width="match_parent"
