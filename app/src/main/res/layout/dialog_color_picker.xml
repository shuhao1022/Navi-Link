<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FF1E1E1E"
    android:gravity="center_horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:text="选择颜色"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_gravity="start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Color Wheel -->
    <com.navi.link.view.ColorWheelView
        android:id="@+id/color_wheel"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Brightness Slider -->
    <TextView
        android:text="亮度"
        android:textColor="#FFAAAAAA"
        android:textSize="11sp"
        android:layout_gravity="start"
        android:layout_marginBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <SeekBar
        android:id="@+id/sb_brightness"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:max="100"
        android:progress="100"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="12dp"
        android:splitTrack="false"
        android:progressDrawable="@android:color/transparent" />

    <!-- Alpha Slider -->
    <TextView
        android:text="透明度"
        android:textColor="#FFAAAAAA"
        android:textSize="11sp"
        android:layout_gravity="start"
        android:layout_marginBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <SeekBar
        android:id="@+id/sb_alpha"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:max="255"
        android:progress="255"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="16dp"
        android:splitTrack="false"
        android:progressDrawable="@android:color/transparent" />

    <!-- Bottom Control Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginBottom="20dp">

        <!-- Color Preview block -->
        <View
            android:id="@+id/view_preview_color"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_width="60dp"
            android:layout_height="28dp" />

        <!-- Hex input text box -->
        <EditText
            android:id="@+id/et_hex_input"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_width="120dp"
            android:layout_height="32dp"
            android:paddingHorizontal="8dp"
            android:background="@drawable/bg_hex_input"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:maxLength="9"
            android:gravity="center"
            android:inputType="textCapCharacters"
            android:digits="0123456789ABCDEFabcdef#"
            android:text="#FFFFFFFF" />
    </RelativeLayout>

    <!-- Buttons -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/btn_cancel_picker"
            android:text="取消"
            android:textColor="#FF888888"
            style="?android:attr/borderlessButtonStyle"
            android:layout_marginEnd="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btn_confirm_picker"
            android:text="确定"
            android:textColor="#FF4FC3F7"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
</LinearLayout>
